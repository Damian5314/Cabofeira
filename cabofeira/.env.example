# Copy this file to .env.local and fill in the values from your Supabase project.
# Project Settings → API → Project URL and "anon public" key.
REACT_APP_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
REACT_APP_SUPABASE_ANON_KEY=your-anon-public-key

# --- Third-party ads (Google AdSense) ---
# Master switch. Keep "false" until the site has enough traffic
# (recommended: >10k monthly visitors) and AdSense approval.
REACT_APP_ADS_ENABLED=false

# Set to "true" to render greyed-out placeholder boxes at every ad
# position. Useful for visually checking layout without loading AdSense.
# Ignored when REACT_APP_ADS_ENABLED=true and a client/slot is set.
REACT_APP_ADS_PREVIEW=false

# AdSense publisher ID, e.g. ca-pub-1234567890123456
REACT_APP_ADS_CLIENT=

# AdSense ad-unit slot IDs (numeric strings from your AdSense dashboard).
REACT_APP_ADS_SLOT_HOME_TOP=
REACT_APP_ADS_SLOT_SEARCH_INLINE=
REACT_APP_ADS_SLOT_INFO_FOOTER=
REACT_APP_ADS_SLOT_NOT_FOUND=
